# ==========================================================================
# Configuration de l'agent prospects WebElite
# Copie ce fichier en « .env » et remplis les valeurs.
# ==========================================================================

# --- Combien de prospects par jour ---
DAILY_TARGET=100

# --- Zone géographique (Québec) ---
# Liste de villes/régions à balayer, séparées par des virgules.
# Tu peux en ajouter/retirer librement.
TARGET_CITIES=Montréal,Québec,Laval,Gatineau,Longueuil,Sherbrooke,Trois-Rivières,Lévis,Saguenay,Terrebonne,Drummondville,Granby,Saint-Jérôme,Repentigny,Saint-Hyacinthe

# ==========================================================================
# LIVRAISON PAR EMAIL (SMTP)
# Exemple avec Gmail : crée un « mot de passe d'application » dans ton compte
# Google (Sécurité > Validation en 2 étapes > Mots de passe des applications).
# ==========================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=ton.email@gmail.com
SMTP_PASS=mot_de_passe_application_16_caracteres

# Expéditeur et destinataire de la liste quotidienne
EMAIL_FROM=WebElite Prospects <ton.email@gmail.com>
EMAIL_TO=mezidi.bilal@gmail.com

# ==========================================================================
# PROSPECTION — envoi de courriels personnalisés aux prospects
# ==========================================================================
# Mode d'envoi : « draft » (brouillons envoyés à TOI pour validation)
#               ou « auto » (envoi direct aux prospects depuis ton adresse).
OUTREACH_MODE=draft
# Nombre maximum de courriels de prospection envoyés par jour.
OUTREACH_DAILY_CAP=40
# Délai entre deux envois, en millisecondes (anti-spam). 8000 = 8 secondes.
OUTREACH_THROTTLE_MS=8000

# --- Identité de l'expéditeur (apparaît dans le courriel) ---
SENDER_NAME=Bilal Mezidi
SENDER_BUSINESS=WebElite
SENDER_PHONE=
# Adresse postale physique — OBLIGATOIRE selon la loi C-28 (LCAP).
SENDER_ADDRESS=
# Lien vers ton portfolio / site (optionnel mais recommandé).
SENDER_PORTFOLIO=
# Adresse de réponse (par défaut = SMTP_USER).
SENDER_REPLY_TO=

# ==========================================================================
# OPTIONNEL — Enrichissement Google Places
# Laisse vide pour utiliser uniquement OpenStreetMap (100% gratuit).
# Si tu mets une clé, l'agent va aussi chercher email/téléphone via Google.
# ==========================================================================
GOOGLE_PLACES_API_KEY=
