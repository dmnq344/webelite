{
  "name": "webelite-prospect-agent",
  "version": "1.0.0",
  "description": "Agent IA qui trouve 100 prospects/jour au Québec sans site web et les envoie par email",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dry-run": "node src/index.js --dry-run",
    "outreach": "node src/index.js --outreach",
    "outreach:dry": "node src/index.js --outreach --dry-run",
    "outreach:auto": "node src/index.js --outreach --auto",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "nodemailer": "^6.9.14"
  }
}
